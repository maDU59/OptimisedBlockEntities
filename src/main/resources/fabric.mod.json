{
	"schemaVersion": 1,
	"id": "obe",
	"version": "${version}",
	"name": "Optimized block entities",
	"description": "Makes block entities render faster",
	"authors": [
		"maDU59_"
	],
	"contact": {
		"homepage": "https://github.com/maDU59/OptimisedBlockEntities",
		"sources": "https://github.com/maDU59/OptimisedBlockEntities",
		"issues": "https://github.com/maDU59/OptimisedBlockEntities/issues"
	},
	"license": "LGPL-3.0-or-later",
	"icon": "assets/obe/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"fr.madu59.obe.OBE"
		],
		"client": [
			"fr.madu59.obe.client.OBEClient"
		],
		"modmenu": [
			"fr.madu59.obe.client.config.configscreen.ModMenuIntegration"
		],
		"sodium:config_api_user": [
            "fr.madu59.obe.client.config.configscreen.SodiumIntegration"
        ]
	},
	"mixins": [
		{
			"config": "obe.client.mixins.json",
			"environment": "client"
		}
	],
	"accessWidener": "obe.classtweaker",
	"depends": {
		"fabricloader": ">=0.19",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"custom": {
		"modmenu": {
			"links": {
				"modmenu.curseforge": "https://www.curseforge.com/minecraft/mc-mods/obe",
				"modmenu.modrinth": "https://modrinth.com/mod/obe",
				"modmenu.discord": "https://discord.gg/ATTZQQeVw4"
			}
		}
	}
}